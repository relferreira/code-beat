# Copy to `.env` for local dev (read by wrangler / the Cloudflare Vite plugin).
# `.env` is gitignored. In production, set these in the Cloudflare dashboard
# (or `wrangler secret put <NAME>`), NOT here.

# Must equal this environment's origin AND the GitHub App callback origin
# (<BETTER_AUTH_URL>/api/auth/callback/github). Locally: http://localhost:3000
BETTER_AUTH_URL=http://localhost:3000
BETTER_AUTH_SECRET=generate-a-long-random-string
GITHUB_CLIENT_ID=your-github-app-client-id
GITHUB_CLIENT_SECRET=your-github-app-client-secret
# Guards the one-time /api/migrate endpoint.
MIGRATE_SECRET=another-random-string
